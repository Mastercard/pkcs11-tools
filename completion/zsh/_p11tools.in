#compdef p11cat p11cp p11importcert p11importdata p11importpubk p11init p11kcv p11keycomp p11keygen p11ls p11mkcert p11more p11mv p11od p11req p11rewrap p11rm p11setattr p11slotinfo p11unwrap p11wrap

# Zsh completion for p11* tools
# This file uses bashcompinit to load and reuse the existing Bash completions

# Load bash completion compatibility layer
autoload -U +X bashcompinit && bashcompinit

# Determine the bash completion directory from installation
# This value is replaced at install time by the Makefile
completion_dir="@COMPLETIONSDIR@"

# Abort if the directory or p11-common is missing
if [[ -z "$completion_dir" || ! -f "$completion_dir/p11-common" ]]; then
    return 1
fi

source "$completion_dir/p11-common"

# List of p11tools commands to load completions for
_p11tools_cmds=(
    p11cat p11cp p11importcert p11importdata p11importpubk p11init
    p11kcv p11keycomp p11keygen p11ls p11mkcert p11more p11mv p11od
    p11req p11rewrap p11rm p11setattr p11slotinfo p11unwrap p11wrap
)

# Source individual bash completion scripts
# We need to override BASH_SOURCE for the sourced files to find p11-common
for cmd in "${_p11tools_cmds[@]}"; do
    if [[ -f "$completion_dir/$cmd" ]]; then
        # Set BASH_SOURCE so the sourced file can find p11-common
        BASH_SOURCE=("$completion_dir/$cmd")
        source "$completion_dir/$cmd" 2>/dev/null || true
    fi
done
